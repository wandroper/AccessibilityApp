<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#CC1565C0">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Tombol toggle (ikon melayang) -->
        <ImageButton
            android:id="@+id/btnToggle"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_compass"
            android:tint="#FFFFFF"
            android:contentDescription="Toggle Menu"/>

        <!-- Panel menu expanded (awalnya GONE) -->
        <LinearLayout
            android:id="@+id/expandedPanel"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="4dp">

            <Button
                android:id="@+id/btnScrollUp"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="⬆ Scroll Atas"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btnScrollDown"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="⬇ Scroll Bawah"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <Button
                android:id="@+id/btnStopScroll"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="⏹ Stop"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D32F2F"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <Button
                android:id="@+id/btnClickTarget"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="🎯 Auto Klik"
                android:textColor="#FFFFFF"
                android:backgroundTint="#388E3C"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
